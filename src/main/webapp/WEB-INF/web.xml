<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Sistema Solar - Educacion de Calidad</display-name>

    <!-- Pagina de inicio del sitio -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- La sesion expira a los 30 minutos de inactividad -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Los servlets y filtros se registran con anotaciones (@WebServlet,
         @WebFilter, @WebListener), por eso este archivo es corto. -->

</web-app>
